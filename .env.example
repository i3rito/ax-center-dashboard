APP_NAME="AX Center"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://laravel7.test

LOG_CHANNEL=stack

DB_CONNECTION=planta_a
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=planta_a
DB_USERNAME=root
DB_PASSWORD=

DB_PLANTA_A_HOST=127.0.0.1
DB_PLANTA_A_PORT=3306
DB_PLANTA_A_DATABASE=planta_a
DB_PLANTA_A_USERNAME=root
DB_PLANTA_A_PASSWORD=

DB_PLANTA_B_HOST=127.0.0.1
DB_PLANTA_B_PORT=3306
DB_PLANTA_B_DATABASE=planta_b
DB_PLANTA_B_USERNAME=root
DB_PLANTA_B_PASSWORD=

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
